INCUS_ENDPOINT=https://incus.local:8443
ESXI_ENDPOINT=https://esxi.local
WORDPRESS_TOKEN=replace-me
AUTH_INTROSPECT_URL=http://localhost:3000/api/auth/introspect
INVITE_ACCEPT_BASE_URL=http://localhost:3000
EMAIL_CRYPTO_KEY=base64-encoded-32-byte-secret

