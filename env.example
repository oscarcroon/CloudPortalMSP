# Frontend
NUXT_PUBLIC_API_BASE=/backend
NUXT_PUBLIC_APP_URL=http://localhost:3000
NUXT_DEV_PROXY_API=http://localhost:4000/api
API_BASE=http://localhost:4000/api
PORTAL_BASE_URL=http://localhost:3000
PASSWORD_RESET_BASE_URL=http://localhost:3000
DB_DIALECT=sqlite
DRIZZLE_DIALECT=sqlite
DRIZZLE_OUT=./src/server/database/migrations
DATABASE_URL=file:./.data/dev.db
DATABASE_URL_MARIA=mysql://user:password@localhost:3306/customer_portal

# SECURITY: These values are ONLY for local development.
# In production, you MUST set strong, unique secrets (min 32 chars for JWT, 16+ for service token).
# The application will refuse to start in production with missing or weak secrets.
AUTH_JWT_SECRET=<generate-strong-secret-min-32-chars>
AUTH_SESSION_TTL=12h
AUTH_SERVICE_TOKEN=<generate-strong-service-token>
CLOUDFLARE_ZT_JWT_SECRET=
AUTH_ALLOW_SELF_REGISTRATION=false
SEED_SUPERADMIN_EMAIL=owner@example.com
SEED_SUPERADMIN_PASSWORD=OwnerPass123!
SEED_SUPERADMIN_NAME=Cloud Portal Owner
LOGIN_BRANDING_SLUG_SUFFIXES=.portal.coreit.cloud
LOGIN_BRANDING_ALLOW_UNVERIFIED=false

# Shared email/outbox
INVITE_ACCEPT_BASE_URL=http://localhost:3000
UPLOADS_DIR=./uploads
EMAIL_CRYPTO_KEY=base64-encoded-32-byte-secret

# Backend
PORT=4000
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CLOUDFLARE_TOKEN=replace-me
INCUS_ENDPOINT=https://incus.local:8443
ESXI_ENDPOINT=https://esxi.local
WORDPRESS_TOKEN=replace-me
AUTH_INTROSPECT_URL=http://localhost:3000/api/auth/introspect

# SECURITY: Required in production to prevent host header poisoning
# PUBLIC_BASE_URL=https://portal.example.com

# Backend introspection cache/timeout settings (optional, shown with defaults)
# AUTH_INTROSPECT_TIMEOUT_MS=2500
# AUTH_INTROSPECT_CACHE_TTL_MS=30000
# AUTH_INTROSPECT_CACHE_MAX=5000

# Frontend introspection rate limiting (optional, shown with defaults)
# AUTH_INTROSPECT_RATE_LIMIT=120
# AUTH_INTROSPECT_RATE_WINDOW_MS=60000

# Trust proxy: set to 1 only if running behind a known reverse proxy
# TRUST_PROXY=1

# =============================================================================
# Windows DNS Redirects Layer - DNS Record Integration
# =============================================================================
# These settings control automatic DNS record creation for redirects.
# Required: At least one public IP must be configured to enable DNS integration.

# Public IPv4 address(es) for Traefik - used for apex (@) A records
# Single IP:
# WINDOWS_DNS_REDIRECTS_PUBLIC_IPV4=203.0.113.10
# Multiple IPs (comma-separated):
# WINDOWS_DNS_REDIRECTS_PUBLIC_IPV4S=203.0.113.10,203.0.113.11

# Public IPv6 address(es) for Traefik - used for apex (@) AAAA records (optional)
# WINDOWS_DNS_REDIRECTS_PUBLIC_IPV6=2001:db8::1
# WINDOWS_DNS_REDIRECTS_PUBLIC_IPV6S=2001:db8::1,2001:db8::2

# CNAME target for subdomain redirects (optional)
# If not set, subdomains will CNAME to the zone apex.
# Set this to your Traefik server's hostname if you want subdomains to point directly to it.
# WINDOWS_DNS_REDIRECTS_CNAME_TARGET=traefik.example.com

# TTL for redirect DNS records in seconds (default: 3600)
# WINDOWS_DNS_REDIRECTS_PUBLIC_TTL=3600

# Comment text added to managed DNS records (default: "[redirects] managed")
# WINDOWS_DNS_REDIRECTS_MANAGED_COMMENT_TEXT=[redirects] managed
