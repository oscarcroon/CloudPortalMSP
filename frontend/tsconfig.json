{
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~": ["./app"],
      "~/*": ["./app/*"],
      "~~": ["."],
      "~~/*": ["./*"],
      "#imports": ["./.nuxt/imports"],
      "server/*": ["./server/*"],
      "@windows-dns/*": ["./layers/windows-dns/*"]
    },
    "skipLibCheck": true
  },
  "exclude": ["scripts/legacy/**"]
}

