{
  "name": "cloud-portal-frontend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "npm run generate:rbac-types && npm run generate:openapi",
    "prebuild": "npm run generate:rbac-types && npm run generate:openapi",
    "generate:rbac-types": "tsx scripts/generate-rbac-types.ts",
    "generate:openapi": "tsx scripts/generate-openapi-routes.ts && tsx scripts/generate-public-operations.ts",
    "dev": "nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview --port 3001 --host 0.0.0.0",
    "lint": "eslint . --ext .ts,.js,.vue",
    "seed": "tsx scripts/seed.ts",
    "seed:user": "tsx scripts/seed-user-standalone.ts",
    "setup": "tsx scripts/setup.ts",
    "db:add-locale": "tsx scripts/add-locale-column.ts",
    "db:fix-users": "tsx scripts/fix-users-table.ts",
    "db:fresh-start": "tsx scripts/fresh-start.ts",
    "db:backfill-owners": "tsx scripts/backfill-owners.ts",
    "migrate:rbac-context-switch": "tsx scripts/migrate-rbac-context-switch.ts",
    "test:unit": "vitest run",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts",
    "lint:plugin-css": "tsx scripts/check-plugin-css.ts",
    "scaffold:plugin": "tsx scripts/scaffold-plugin.ts",
    "db:create-delegation-tables": "tsx scripts/create-delegation-tables.ts",
    "db:fix-delegation-tables": "tsx scripts/fix-delegation-tables.ts",
    "db:verify-delegation-tables": "tsx scripts/verify-delegation-tables.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@coreit/email-kit": "file:../packages/email-kit",
    "@iconify/vue": "^5.0.0",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/i18n": "^10.0.6",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@pinia/nuxt": "^0.5.5",
    "@vueuse/core": "^14.1.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.44.7",
    "isomorphic-dompurify": "^2.35.0",
    "jsonwebtoken": "^9.0.2",
    "jszip": "^3.10.1",
    "marked": "^17.0.1",
    "mysql2": "^3.11.3",
    "nuxt": "^4.2.1",
    "pinia": "^2.1.7",
    "sanitize-html": "^2.17.0",
    "vue": "^3.5.11",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/simple-icons": "^1.2.59",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.21.1",
    "openapi-types": "^12.1.3",
    "postcss": "^8.4.45",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.20.6",
    "typescript": "^5.6.3",
    "vitest": "^1.4.1",
    "vue-eslint-parser": "^10.2.0"
  }
}
