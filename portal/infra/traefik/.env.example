# Traefik Edge Server Environment Variables

# Let's Encrypt email for certificate notifications
TRAEFIK_ACME_EMAIL=ssl-admin@example.com

# Default domain for Traefik dashboard
TRAEFIK_DEFAULT_DOMAIN=portal.example.com

# Dashboard authentication (generate with: htpasswd -nb admin yourpassword)
# Note: Double $ signs in docker-compose ($$)
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$xyz$hash
